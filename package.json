{
  "name": "al-ocr-project",
  "version": "1.2.0",
  "private": true,
  "description": "Professional Iterative OCR & Pixel Reconstruction Project",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arisofia/AL-OCR-Project.git"
  },
  "scripts": {
    "dev:up": "./tools/dev_up.sh",
    "dev:down": "./tools/dev_down.sh",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:lint": "cd frontend && npm run lint",
    "deploy": "./tools/deploy_app.sh",
    "api:dev": "python -m ocr_service.main",
    "test:all": "pytest ocr_service/tests/ ocr_reconstruct/tests/",
    "lint:python": "ruff check .",
    "format:python": "ruff format .",
    "validate:repo": "./tools/validate_repo.sh",
    "verify:cicd": "./tools/verify_cicd.sh",
    "check:deploy-secrets": "./tools/check_deploy_secrets.sh",
    "set:repo-secrets": "./scripts/set_repo_secrets.sh --help"
  }
}
