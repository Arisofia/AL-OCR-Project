{
  "$schema": "https://raw.githubusercontent.com/microsoft/pyright/main/packages/pyright/schema/pyrightconfig.schema.json",
  "include": [
    "ocr_service",
    "scripts"
  ],
  "exclude": [
    "**/.*",
    "**/node_modules",
    "**/__pycache__",
    ".venv",
    "**/site-packages/**",
    "ocr_service/tests",
    "frontend",
    "node_modules"
  ],
  "ignore": [
    ".venv",
    "**/site-packages/**"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "basic"
}
